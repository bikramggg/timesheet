# Jira (Atlassian Cloud)
JIRA_SITE=yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=
JIRA_ACCOUNT_ID=
# Browser-facing base URL used in dashboard links. Defaults to https://${JIRA_SITE}
JIRA_BASE_URL=

# GitHub
GITHUB_USERNAME=
GITHUB_TOKEN=

# Google Calendar — secret ICS URL from Calendar settings -> "Integrate calendar" -> "Secret address in iCal format"
GCAL_ICS_URL=

# LM Studio (optional, for AI daily summaries)
LMSTUDIO_URL=
LMSTUDIO_MODEL=

# Storage
DB_PATH=./data/timesheet.db
LOCAL_DATA_DIR=./data/local

# Server
TIMEZONE=Asia/Kolkata
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ntfy notifications (optional)
NTFY_URL=
NTFY_TOPIC=
NTFY_TOKEN=

# Worklog plan: fallback issue key for meetings whose title has no TF-xxxx
DEFAULT_MEETING_KEY=

# Mac push webhook — RPi calls this when "Run now" is clicked, to fetch fresh local data.
# Format: http://<mac-host>:<port>  (use Tailscale magic DNS or LAN IP, NOT localhost)
MAC_PUSH_URL=
MAC_PUSH_TOKEN=
